# Copy this file to `.env` (in the same backend/ folder) and fill in your key.
# `.env` is git-ignored so your key is never committed.
#
#   cp .env.example .env      # then edit .env and paste your key
#
# Get a key at https://console.anthropic.com/ → API keys.
ANTHROPIC_API_KEY=

# Optional — which Claude model powers the AI features. Defaults to
# claude-opus-4-8. Use claude-haiku-4-5 for cheaper/faster (some quality cost).
# ANTHROPIC_MODEL=claude-opus-4-8
